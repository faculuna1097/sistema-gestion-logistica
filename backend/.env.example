# Variables de entorno del backend
# Copiá este archivo como .env y completá los valores reales.
# El archivo .env nunca se commitea al repo (está en .gitignore).

# Connection string de PostgreSQL (Supabase Session Pooler)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-x-region.pooler.supabase.com:5432/postgres

# Puerto en el que escucha el servidor
# En desarrollo local: 3000
# En producción (Render/Railway): la plataforma lo asigna dinámicamente,
# esta variable se ignora si la plataforma define la suya.
PORT=3000

# Secreto para firmar JWTs (autenticación)
# Generar uno random largo en producción. Ejemplo de comando:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar-por-string-random-largo

# Orígenes permitidos por CORS, separados por coma sin espacios
# En desarrollo local:  http://localhost:5173
# En producción:        http://localhost:5173,https://tu-app.vercel.app
CORS_ORIGINS=http://localhost:5173
